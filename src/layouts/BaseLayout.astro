---
import { Font } from 'astro:assets'
import '../assets/css/main.css'

interface Props {
  title: string
  description: string
  ogUrl: string
  lang: string
}

const { title, description, ogUrl, lang } = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://picsum.photos/id/988/1200/630" />
    <meta property="og:url" content={ogUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://picsum.photos/id/988/1200/630" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <Font cssVariable="--font-inter" preload={[{ weight: 400, style: 'normal' }]} />
    <Font cssVariable="--font-merriweather" preload={[{ weight: 400, style: 'normal' }]} />
    <Font cssVariable="--font-source-code-pro" />
    <script defer src="https://analytics.zorygo.ovh/js/pa-rZeXMBjHeyBgH948AJs7u.js"></script>
    <script is:inline>
      window.plausible = window.plausible || function () { (plausible.q = plausible.q || []).push(arguments) }
      plausible.init = plausible.init || function (i) { plausible.o = i || {} }
      plausible.init()
    </script>
    <script is:inline>
      (function () {
        var m = document.cookie.match(/(?:^|; )theme=([^;]*)/)
        var theme = m ? decodeURIComponent(m[1]) : 'system'
        if (theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>
  </head>
  <body class="bg-zinc-100 dark:bg-zinc-950">
    <div class="container sm:p-10 lg:p-20">
      <slot />
    </div>
    <slot name="body-scripts" />
  </body>
</html>
