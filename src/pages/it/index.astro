---
import resumeData from '../../assets/resume.it.json'
import TheFooter from '../../components/TheFooter.astro'
import TheResume from '../../components/TheResume.astro'
import { useTranslations } from '../../i18n/utils'
import BaseLayout from '../../layouts/BaseLayout.astro'

const t = useTranslations('it')
const { basics, work, education, skills, projects, languages } = resumeData

const title = 'Francesco Zorzi | Software Engineer | Curriculum'
const description = 'Software Engineer con esperienza nella guida di team di sviluppo. Competenze in Vue.js, .NET, PostgreSQL.'
---

<BaseLayout title={title} description={description} ogUrl="https://resume.francescozorzi.me/it/" lang="it">
  <TheResume basics={basics} work={work} education={education} skills={skills} projects={projects} languages={languages} t={t} currentLocale="it" />
  <TheFooter t={t} currentLocale="it" />
  <script slot="body-scripts" is:inline>
    document.cookie = 'locale=it; max-age=31536000; path=/; SameSite=Lax; Secure'
  </script>
</BaseLayout>
