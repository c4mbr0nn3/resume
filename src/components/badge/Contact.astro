---
import { Icon } from 'astro-icon/components'

const { item } = Astro.props
const isExternal = item.to.startsWith('http')
---

<a
  href={item.to}
  class="flex items-center gap-2 text-orange-600 hover:text-orange-700 hover:underline transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-600 dark:text-orange-400 dark:hover:text-orange-300 dark:focus-visible:outline-orange-400"
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
>
  <Icon name={item.icon} class="w-5 h-5" />
  <span class="font-light">{item.label}</span>
</a>
