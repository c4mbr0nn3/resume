---
import { Icon } from 'astro-icon/components'
import { skillIcons } from '../../lib/icons.js'

const { skill } = Astro.props
const icon = skillIcons[skill.toLowerCase()]
---

<div class="flex items-center gap-1 text-orange-600 hover:text-orange-700 transition-colors text-sm dark:text-orange-400 dark:hover:text-orange-300">
  {icon && <Icon name={icon} class="w-4 h-4" />}
  {skill}
</div>
