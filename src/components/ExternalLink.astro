---
import { Icon } from 'astro-icon/components'

const { href, label } = Astro.props
---

{href
? (
  <a
    href={href}
    class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300 transition-colors"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span>{label}</span>
    <Icon name="carbon:launch" class="w-3.5 h-3.5" />
  </a>
)
: (
  <span class="text-indigo-600 dark:text-indigo-400">{label}</span>
)}
