---
import { Icon } from 'astro-icon/components'

const { t, currentLocale } = Astro.props
const buildDate = new Date().toLocaleDateString(currentLocale === 'it' ? 'it-IT' : 'en-GB', { month: 'long', year: 'numeric' }).replace(/^\w/, c => c.toUpperCase())
---

<footer class="text-center text-zinc-500 dark:text-zinc-400 font-light py-10 sm:pb-10">
  <div class="flex flex-col items-center justify-center gap-1 sm:flex-row sm:gap-3">
    <p>{t['footer.lastUpdate']} {buildDate}</p>
    <span class="hidden sm:block">-</span>
    <p class="flex items-center">
      {t['footer.forkText']}&nbsp;
      <a
        href="https://gitlab.com/j1mm0/resume"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1 text-indigo-600 hover:text-indigo-700 transition-all dark:text-indigo-400 dark:hover:text-indigo-300"
      >
        GitLab
        <Icon name="simple-icons:gitlab" />
      </a>
      &nbsp;{t['footer.or']}&nbsp;
      <a
        href="https://github.com/c4mbr0nn3/resume"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1 text-indigo-600 hover:text-indigo-700 transition-all dark:text-indigo-400 dark:hover:text-indigo-300"
      >
        GitHub
        <Icon name="simple-icons:github" />
      </a>
    </p>
  </div>
</footer>
