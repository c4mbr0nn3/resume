---
import { Icon } from 'astro-icon/components'

const { t, currentLocale } = Astro.props
const buildDate = new Date().toLocaleDateString(currentLocale === 'it' ? 'it-IT' : 'en-GB', { month: 'long', year: 'numeric' }).replace(/^\w/, c => c.toUpperCase())
---

<footer class="text-center text-stone-500 dark:text-stone-400 font-light py-10 sm:pb-10">
  <div class="flex flex-col items-center justify-center gap-1 sm:flex-row sm:gap-3">
    <p>{t['footer.lastUpdate']} {buildDate}</p>
    <span class="hidden sm:block">-</span>
    <p class="flex items-center">
      {t['footer.forkText']}&nbsp;
      <a
        href="https://gitlab.com/j1mm0/resume"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1 text-orange-600 hover:text-orange-700 hover:underline transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-600 dark:text-orange-400 dark:hover:text-orange-300 dark:focus-visible:outline-orange-400"
      >
        GitLab
        <Icon name="simple-icons:gitlab" />
      </a>
      &nbsp;{t['footer.or']}&nbsp;
      <a
        href="https://github.com/c4mbr0nn3/resume"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1 text-orange-600 hover:text-orange-700 hover:underline transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-600 dark:text-orange-400 dark:hover:text-orange-300 dark:focus-visible:outline-orange-400"
      >
        GitHub
        <Icon name="simple-icons:github" />
      </a>
    </p>
  </div>
  <div class="text-xs mt-3 sm:mt-2">
    {t['footer.thanks']}&nbsp;
    <a
      href="https://nathanfriend.io"
      target="_blank"
      rel="noopener noreferrer"
      class="text-orange-600 hover:text-orange-700 hover:underline transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-600 dark:text-orange-400 dark:hover:text-orange-300 dark:focus-visible:outline-orange-400"
    >
      Nathan Friend&nbsp;
    </a>
    {t['footer.inspiration']}
  </div>
</footer>
