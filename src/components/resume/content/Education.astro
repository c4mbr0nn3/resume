---
import ExternalLink from '../../ExternalLink.astro'
import Title from './Title.astro'

const { education, t } = Astro.props
---

<section>
  <Title title={t.education} />
  {education.map((item: any) => (
    <div class="mb-5">
      <div class="flex flex-col gap-1">
        <h3 class="text-lg font-semibold text-balance">
          <ExternalLink href={item.url} label={item.institution} />
        </h3>
        <p class="text-sm font-mono text-stone-600 dark:text-stone-400">
          {item.startDate} - {item.endDate}
        </p>
      </div>
      <p class="font-light text-stone-600 dark:text-stone-400">{item.studyType} in {item.area}</p>
    </div>
  ))}
</section>
