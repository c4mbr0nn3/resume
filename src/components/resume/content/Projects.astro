---
import ExternalLink from '../../ExternalLink.astro'
import SkillList from '../../list/Skill.astro'
import Markdown from '../../Markdown.astro'
import Title from './Title.astro'

const { projects, t } = Astro.props
---

<section>
  <Title title={t.projects} />
  {projects.map((item: any) => (
    <div class="mb-5">
      <div class="flex flex-col justify-between gap-1 sm:flex-row sm:items-center">
        <h3 class="text-lg font-semibold text-balance">
          <ExternalLink href={item.url} label={item.name} />
        </h3>
        <p class="text-sm font-mono text-stone-600 dark:text-stone-400">
          {item.startDate} - {item.endDate}
        </p>
      </div>
      <p class="mb-2 mt-1">
        <Markdown content={item.description} />
      </p>
      <p>
        <SkillList items={item.highlights} />
      </p>
    </div>
  ))}
</section>
