---
import LanguageSwitcher from './LanguageSwitcher.astro'
import Content from './resume/content/Index.astro'
import Header from './resume/Header.astro'
import Summary from './resume/Summary.astro'

const { basics, work, education, skills, projects, languages, t, currentLocale } = Astro.props
---

<div class="relative w-full bg-white sm:rounded-xl sm:shadow-lg">
  <LanguageSwitcher currentLocale={currentLocale} />
  <div class="flex flex-col gap-5 p-5 sm:p-10 sm:gap-10">
    <Header basics={basics} />
    <Summary basics={basics} />
    <Content work={work} education={education} skills={skills} projects={projects} languages={languages} t={t} />
  </div>
</div>
