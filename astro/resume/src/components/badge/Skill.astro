---
import { Icon } from 'astro-icon/components'
import { skillIcons } from '../../lib/icons.js'

const { skill } = Astro.props
const icon = skillIcons[skill.toLowerCase()]
---

<div class="flex items-center gap-1 p-2 rounded border border-indigo-200 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 transition-colors text-sm dark:bg-indigo-950 dark:border-indigo-800 dark:text-indigo-300 dark:hover:bg-indigo-900">
  {icon && <Icon name={icon} class="w-4 h-4" />}
  {skill}
</div>
