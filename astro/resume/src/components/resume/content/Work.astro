---
import ExternalLink from '../../ExternalLink.astro'
import Markdown from '../../Markdown.astro'
import Title from './Title.astro'
import WorkHighlight from './WorkHighlight.astro'

const { work, t } = Astro.props
---

<section>
  <Title title={t.work} />
  {work.map((item: any) => (
    <div class="mb-5">
      <div class="flex justify-between items-center">
        <h3 class="text-lg font-semibold">
          <ExternalLink href={item.url} label={item.name} />
        </h3>
        <p class="text-sm font-mono text-slate-500">
          {item.startDate} - {item.endDate}
        </p>
      </div>
      <p class="text-sm font-serif text-slate-500 font-medium">{item.position}</p>
      <p class="mb-2 mt-1">
        <Markdown content={item.summary} />
      </p>
      <p>
        {item.highlights.map((content: string) => (
          <WorkHighlight content={content} />
        ))}
      </p>
    </div>
  ))}
</section>
